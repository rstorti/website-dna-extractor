# ==============================
# AI Provider Keys
# ==============================
# Used for backend website/youtube verification formatting
GEMINI_API_KEY=

# ==============================
# External API Keys (YouTube/Others)
# ==============================
# Required to fetch channel names & raw Youtube video descriptions
YOUTUBE_API_KEY=
VITE_YOUTUBE_API_KEY=

# Used optionally for fallback scraper capabilities
FIRECRAWLER_API_KEY=

# ==============================
# Supabase Integration
# ==============================
# Supabase Project Instance URL
SUPABASE_URL=
# Client-side / Anon REST Key
SUPABASE_ANON_KEY=

# ==============================
# Google Cloud Platform (Optional)
# ==============================
GCP_PROJECT_ID=
# Path or base64 JSON string representing your Vertex service account key
GOOGLE_APPLICATION_CREDENTIALS=

# ==============================
# Server Config
# ==============================
PORT=3001
NODE_ENV=development
# Set automatically by Render.com — used to build public /outputs/ URLs
# For local dev, leave blank (defaults to http://localhost:PORT)
RENDER_EXTERNAL_URL=
