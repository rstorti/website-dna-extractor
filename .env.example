# ==============================
# AI Provider Keys
# ==============================
# Used for backend website/youtube verification formatting
GEMINI_API_KEY=

# ==============================
# External API Keys (YouTube/Others)
# ==============================
# Required to fetch channel names & raw Youtube video descriptions
YOUTUBE_API_KEY=
VITE_YOUTUBE_API_KEY=

# Used optionally for fallback scraper capabilities
FIRECRAWLER_API_KEY=

# ==============================
# Supabase Integration
# ==============================
# Supabase Project Instance URL
SUPABASE_URL=
# Backend write key. Required in production for durable history/jobs.
SUPABASE_SERVICE_ROLE_KEY=
# Optional client-side / anon REST key
SUPABASE_ANON_KEY=

# ==============================
# Google Cloud Platform (Optional)
# ==============================
ENABLE_IMAGE_GENERATION=false
GCP_PROJECT_ID=
# Path or base64 JSON string representing your Vertex service account key
GOOGLE_APPLICATION_CREDENTIALS=
GCP_CREDENTIALS_JSON=
GCP_LOCATION=us-central1

# ==============================
# Server Config
# ==============================
PORT=3001
NODE_ENV=development
# Set automatically by Render.com — used to build public /outputs/ URLs
# For local dev, leave blank (defaults to http://localhost:PORT)
RENDER_EXTERNAL_URL=
REQUIRE_NETWORK_EGRESS_LOCKDOWN=false
# Set to enabled only after container/VPC egress blocks private networks and metadata services.
NETWORK_EGRESS_LOCKDOWN_ACK=

# ==============================
# API Authentication (REQUIRED in production)
# ==============================
# Protects the Dart client API (/api/dart/*).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED when NODE_ENV=production — server will exit(1) if missing.
DART_API_KEY=

# Protects the history read/delete endpoints (/api/history).
# Use the same generation method as DART_API_KEY.
# REQUIRED when NODE_ENV=production — requests will be rejected with 401 if missing.
HISTORY_API_KEY=

# Protects the extraction job trigger (/api/jobs POST).
# If set, callers must supply:  Authorization: Bearer <JOB_API_KEY>
# Recommended in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# NOTE: The frontend must also set this in Netlify build vars as VITE_JOB_API_KEY if you enable this.
JOB_API_KEY=

# NOTE: VITE_HISTORY_API_KEY is NO LONGER USED.
# The frontend now fetches a short-lived session token from /api/history/session.
# The raw HISTORY_API_KEY never leaves the server. Remove VITE_HISTORY_API_KEY from
# your Netlify environment variables if it was previously set there.
